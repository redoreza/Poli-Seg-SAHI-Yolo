# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# Konfigurasi Flask
SECRET_KEY=ganti_dengan_secret_key_anda_yang_unik
DEBUG=False

# Konfigurasi Folder
UPLOAD_FOLDER=static/uploads
RESULT_FOLDER=static/results
ANNOTATION_FOLDER=static/annotations
DATASET_FOLDER=static/dataset

# Konfigurasi Model
MODEL_FOLDER=models
ACTIVE_MODEL_FILE=models/active_model.txt

# Konfigurasi Lainnya
VIDEO_OUTPUT_FPS=30
